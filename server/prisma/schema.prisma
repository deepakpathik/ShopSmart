generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SELLER
  CUSTOMER
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String    @default("")
  role      Role      @default(CUSTOMER)
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  imageUrl    String   @default("")
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
